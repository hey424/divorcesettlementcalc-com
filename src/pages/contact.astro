---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Contact | divorcesettlementcalc.com';
const description = 'Contact the divorcesettlementcalc.com editorial team with corrections, feedback, or questions.';
---
<BaseLayout title={title} description={description}>
  <h1>Contact</h1>
  <p>For corrections, feedback, or questions about the calculator or guides, email <a href="mailto:hey@theclicklab.agency">hey@theclicklab.agency</a>.</p>
  <p>We read every message and take accuracy reports seriously. If you have found a factual error, an outdated legal reference, or a calculation result that appears incorrect, please include the specific page URL and the detail you believe is wrong. We review and correct confirmed errors as quickly as possible.</p>
  <p>We are not able to provide legal advice or respond to requests for case-specific analysis. If you are going through a divorce proceeding, please consult a licensed family law attorney in your state. Many family law attorneys offer free initial consultations, and some states have legal aid organizations that provide free assistance to qualifying individuals.</p>
</BaseLayout>
