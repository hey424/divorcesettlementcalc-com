---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Privacy Policy | divorcesettlementcalc.com';
const description = 'Privacy policy for divorcesettlementcalc.com — how we handle data, cookies, and third-party services.';
---
<BaseLayout title={title} description={description}>
  <h1>Privacy Policy</h1>
  <p><strong>Effective date:</strong> January 1, 2026</p>

  <h2>Information we collect</h2>
  <p>divorcesettlementcalc.com does not collect personal information directly. We do not require account registration, email submission, or any form completion to use the calculator or read the guides. All calculator inputs are processed locally in your browser and are not transmitted to our servers.</p>

  <h2>Cookies and advertising</h2>
  <p>This site uses Google AdSense to display advertisements. Google AdSense sets cookies to serve relevant ads based on your browsing activity. These cookies are set by Google, not by divorcesettlementcalc.com, and are subject to Google&rsquo;s privacy policy. You can manage your Google ad preferences at <a href="https://adssettings.google.com" target="_blank" rel="noopener">adssettings.google.com</a>.</p>

  <h2>Analytics</h2>
  <p>We use Google Analytics to collect aggregate traffic data — page views, session counts, and general geographic distribution. This data is anonymized and used only to understand site usage patterns. We do not use it to identify individual visitors. Google Analytics data is subject to Google&rsquo;s privacy policy.</p>

  <h2>Third-party services</h2>
  <p>The only third-party services active on this site are Google AdSense and Google Analytics, both operated by Google LLC. Both services are subject to Google&rsquo;s <a href="https://policies.google.com/privacy" target="_blank" rel="noopener">Privacy Policy</a>.</p>

  <h2>Your choices</h2>
  <p>You can opt out of Google&rsquo;s interest-based advertising at <a href="https://adssettings.google.com" target="_blank" rel="noopener">Google Ad Settings</a>. You can also install the <a href="https://tools.google.com/dlpage/gaoptout" target="_blank" rel="noopener">Google Analytics Opt-out Browser Add-on</a> to prevent Google Analytics from collecting data about your visits.</p>

  <h2>Contact</h2>
  <p>Questions about this privacy policy? Email <a href="mailto:hey@theclicklab.agency">hey@theclicklab.agency</a>.</p>
</BaseLayout>
